# base dir
ZSH_CONFIG="$HOME/.config/zsh"

case "$(uname -s)" in
  Darwin) ZSH_PLATFORM="darwin" ;;
  Linux) ZSH_PLATFORM="linux" ;;
  *) ZSH_PLATFORM="unknown" ;;
esac

source_zsh_file() {
  [[ -r "$1" ]] && source "$1"
}

source_zsh_file "$ZSH_CONFIG/common.zsh"
source_zsh_file "$ZSH_CONFIG/$ZSH_PLATFORM.zsh"

autoload -Uz compinit
compinit
